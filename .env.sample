# DEV = show OTP on screen | PROD = send SMS only (no OTP in UI)
# DEV = public test page works without admin login
VITE_ENV=DEV

# API URL — optional in local dev; app auto-uses same host as the page (LAN IP on phone).
# VITE_API_BASE_URL=http://localhost:4010
# VITE_SOCKET_URL=http://localhost:4010
VITE_API_BASE_URL=http://localhost:4010
VITE_ADMIN_API_PATH=/api/v1/alarm/admin
VITE_USER_API_PATH=/api/v1/alarm/user
VITE_SOCKET_URL=http://localhost:4010

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
